# IBM App ID (OIDC) — obtain from IBM Cloud App ID dashboard
APPID_ISSUER_URL=https://us-south.appid.cloud.ibm.com/oauth/v4/<tenantId>
APPID_JWKS_URL=https://us-south.appid.cloud.ibm.com/oauth/v4/<tenantId>/publickeys
APPID_AUDIENCE=<client_id>

# Upstream service URLs (overridden in OCP via ConfigMap)
AGENT1_URL=http://agent1-svc
AGENT2_URL=http://agent2-svc
ORCHESTRATE_URL=http://orchestrate-svc

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# Upstream timeouts (seconds)
UPSTREAM_CONNECT_TIMEOUT=5.0
UPSTREAM_READ_TIMEOUT=120.0

# Service identity
SERVICE_NAME=gateway
LOG_LEVEL=INFO
ENVIRONMENT=production
