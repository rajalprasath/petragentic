# IBM Cloud credentials
IBM_CLOUD_API_KEY=<your-ibm-cloud-api-key>

# watsonx.ai (private endpoint)
WATSONX_URL=https://private.us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=<your-watsonx-project-id>
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
WATSONX_MAX_NEW_TOKENS=2048
WATSONX_TEMPERATURE=0.0
WATSONX_REPETITION_PENALTY=1.05

# Upstream skill endpoints (override for Docker Compose / local dev)
AGENT1_URL=http://agent1-svc
AGENT2_URL=http://agent2-svc

# Conversation memory
MAX_CONVERSATION_TURNS=20
MAX_REACT_ITERATIONS=8

# Upstream HTTP timeouts (seconds)
SKILL_CONNECT_TIMEOUT=5.0
SKILL_READ_TIMEOUT=120.0

# Service identity
SERVICE_NAME=orchestrate
LOG_LEVEL=INFO
ENVIRONMENT=production
